# Docker-specific Audrey configuration
# Copy to .env and edit before running: docker compose up -d --build

# ---------------------------------------------------------------------------
# REQUIRED — fail-closed if missing
# ---------------------------------------------------------------------------

# Bearer token for REST API auth. Compose refuses to start without this.
# Generate with:  openssl rand -hex 32
# Leave empty in the template so a verbatim copy fails closed.
AUDREY_API_KEY=

# ---------------------------------------------------------------------------
# Provider selection
# ---------------------------------------------------------------------------

# Embedding provider: local | gemini | openai (default: local, 384 dimensions)
AUDREY_EMBEDDING_PROVIDER=local

# Device for local embeddings: cpu | gpu (default: cpu inside Docker;
# the linux/amd64 image does not ship CUDA — keep on cpu unless you wired
# a GPU runtime into the host)
AUDREY_DEVICE=cpu

# LLM provider for consolidation / reflection (optional)
# AUDREY_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# Gemini embeddings (alternative to local)
# GOOGLE_API_KEY=

# OpenAI embeddings (alternative to local)
# OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Networking
# ---------------------------------------------------------------------------

# Published port on host (default: 3487)
# AUDREY_PUBLISHED_PORT=3487

# ---------------------------------------------------------------------------
# Security toggles — leave defaults unless you know why
# ---------------------------------------------------------------------------

# Admin tools (export, import, forget). OFF by default. Setting this to 1
# exposes destructive routes that can wipe or replace the entire memory store.
# AUDREY_ENABLE_ADMIN_TOOLS=0

# AUDREY_ALLOW_NO_AUTH is intentionally NOT supported in this Docker
# deployment. The compose file enforces AUDREY_API_KEY. Setting NO_AUTH=1 on
# a publicly bound sidecar would let any caller read or modify memories.

# Debug logging. Off by default. Audrey errors always log to stderr regardless.
# AUDREY_DEBUG=0

# ---------------------------------------------------------------------------
# Resource ceilings — override for larger workloads
# ---------------------------------------------------------------------------

# Memory ceiling for the container (e.g. 1g, 2g, 512m). Default: 1g.
# Local 384-dim provider needs ~512 MiB headroom during model warmup.
# AUDREY_MEM_LIMIT=1g

# CPU ceiling as a decimal core count (e.g. 1.0, 2.0, 0.5). Default: 1.0.
# AUDREY_CPU_LIMIT=1.0
