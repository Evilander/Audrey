{
  "name": "audrey",
  "version": "0.23.0",
  "description": "Local-first memory runtime for AI agents with recall, consolidation, memory reflexes, contradiction detection, and tool-trace learning",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp-server/index.d.ts",
      "default": "./dist/mcp-server/index.js"
    },
    "./server": {
      "types": "./dist/src/server.d.ts",
      "default": "./dist/src/server.js"
    }
  },
  "bin": {
    "audrey": "dist/mcp-server/index.js",
    "audrey-mcp": "dist/mcp-server/index.js"
  },
  "files": [
    "benchmarks/*.js",
    "benchmarks/snapshots/*.json",
    "dist/",
    "docs/AUDREY_PAPER_OUTLINE.md",
    "docs/MEMORY_BENCHMARKING.md",
    "docs/PRODUCTION_BACKLOG.md",
    "docs/assets/audrey-feature-grid.jpg",
    "docs/assets/audrey-logo.svg",
    "docs/assets/audrey-wordmark.png",
    "examples/",
    "CHANGELOG.md",
    "README.md",
    "SECURITY.md",
    "LICENSE",
    "scripts/smoke-cli.js"
  ],
  "scripts": {
    "build": "tsc",
    "prebuild": "node --input-type=module -e \"import fs from 'node:fs'; fs.rmSync('dist',{recursive:true,force:true})\"",
    "pretest": "npm run build && npm run bench:perf",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:gate": "npm run typecheck && npm test && npm run bench:memory:check && npm run smoke:cli && npm run pack:check",
    "release:gate:sandbox": "npm run build && npm run typecheck && npm run bench:perf && npm run bench:memory:check && npm run smoke:cli && npm run pack:check",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run",
    "smoke:cli": "node scripts/smoke-cli.js",
    "bench:memory": "node benchmarks/run.js",
    "bench:perf": "node benchmarks/perf.bench.js",
    "bench:perf-snapshot": "node benchmarks/perf-snapshot.js",
    "bench:memory:retrieval": "node benchmarks/run.js --suite retrieval",
    "bench:memory:operations": "node benchmarks/run.js --suite operations",
    "bench:memory:guard": "node benchmarks/run.js --suite guard",
    "bench:memory:json": "node benchmarks/run.js --json",
    "bench:memory:check": "node benchmarks/run.js --check",
    "typecheck": "tsc --noEmit",
    "serve": "node dist/mcp-server/index.js serve",
    "docker:build": "docker build -t audrey:local .",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f audrey"
  },
  "keywords": [
    "ai",
    "memory",
    "agents",
    "llm",
    "cognitive",
    "sqlite",
    "embedding",
    "mcp",
    "biological-memory",
    "episodic-memory",
    "semantic-memory",
    "forgetting-curve",
    "vector-search",
    "knowledge-graph",
    "causal-graph",
    "ai-agent",
    "model-context-protocol",
    "recall",
    "consolidation",
    "confidence",
    "long-term-memory",
    "persistent-memory",
    "memory-preflight",
    "memory-reflexes",
    "agent-reflexes",
    "agent-safety",
    "tool-trace-memory",
    "local-first-memory",
    "rag",
    "claude",
    "agent-framework",
    "rest-api",
    "http-server"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Evilander/Audrey.git"
  },
  "homepage": "https://github.com/Evilander/Audrey",
  "bugs": {
    "url": "https://github.com/Evilander/Audrey/issues"
  },
  "author": "evilander",
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "hono": "^4.12.18",
    "sqlite-vec": "^0.1.9",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "directories": {
    "example": "examples",
    "test": "tests"
  }
}
