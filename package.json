{
  "name": "audrey",
  "version": "0.16.1",
  "description": "Biological memory architecture for AI agents - encode, consolidate, and recall memories with confidence decay, contradiction detection, and causal graphs",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./mcp": "./mcp-server/index.js"
  },
  "bin": {
    "audrey": "mcp-server/index.js",
    "audrey-mcp": "mcp-server/index.js"
  },
  "files": [
    "src/",
    "mcp-server/",
    "benchmarks/*.js",
    "docs/production-readiness.md",
    "docs/benchmarking.md",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:check": "npm pack --dry-run",
    "bench:memory": "node benchmarks/run.js",
    "bench:memory:json": "node benchmarks/run.js --json",
    "bench:memory:check": "node benchmarks/run.js --check",
    "bench:memory:readme-assets": "node benchmarks/run.js --readme-assets-dir docs/assets/benchmarks",
    "serve": "node mcp-server/index.js serve"
  },
  "keywords": [
    "ai",
    "memory",
    "agents",
    "llm",
    "cognitive",
    "sqlite",
    "embedding",
    "mcp",
    "biological-memory",
    "episodic-memory",
    "semantic-memory",
    "forgetting-curve",
    "vector-search",
    "knowledge-graph",
    "causal-graph",
    "ai-agent",
    "model-context-protocol",
    "recall",
    "consolidation",
    "confidence",
    "long-term-memory",
    "persistent-memory",
    "rag",
    "claude",
    "agent-framework",
    "rest-api",
    "http-server",
    "fintech",
    "healthcare"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Evilander/Audrey.git"
  },
  "homepage": "https://github.com/Evilander/Audrey",
  "bugs": {
    "url": "https://github.com/Evilander/Audrey/issues"
  },
  "author": "evilander",
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^12.6.2",
    "sqlite-vec": "^0.1.7-alpha.2",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}
