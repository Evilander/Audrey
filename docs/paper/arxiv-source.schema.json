{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audrey-memory.org/schemas/audrey-arxiv-source-manifest.schema.json",
  "title": "Audrey arXiv Source Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "generatedAt", "sourceMarkdown", "publicationPack", "sourceHashes", "files", "tex"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "suite": { "const": "Audrey arXiv source package" },
    "generatedAt": { "type": "string", "minLength": 1 },
    "sourceMarkdown": { "type": "string", "minLength": 1 },
    "publicationPack": { "type": "string", "minLength": 1 },
    "sourceHashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceMarkdown", "publicationPack", "referencesBib"],
      "properties": {
        "sourceMarkdown": { "$ref": "#/$defs/sha256" },
        "publicationPack": { "$ref": "#/$defs/sha256" },
        "referencesBib": { "$ref": "#/$defs/sha256" }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/fileRecord" }
    },
    "tex": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mainFile", "titleEntry", "abstractEntry", "citationCount", "bibEntryCount", "codeBlocks", "tableBlocks"],
      "properties": {
        "mainFile": { "const": "main.tex" },
        "titleEntry": { "const": "arxiv-title" },
        "abstractEntry": { "const": "arxiv-abstract" },
        "citationCount": { "type": "integer", "minimum": 1 },
        "bibEntryCount": { "type": "integer", "minimum": 1 },
        "codeBlocks": { "type": "integer", "minimum": 0 },
        "tableBlocks": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "fileRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "source", "bytes", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
