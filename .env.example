# Audrey Memory Configuration
# Copy to .env or set as environment variables

# Data directory (default: ~/.audrey/data)
# AUDREY_DATA_DIR=./audrey-data

# Agent identifier (host-specific in generated config)
# AUDREY_AGENT=my-agent

# Embedding provider: local | gemini | openai | mock (default: local)
# AUDREY_EMBEDDING_PROVIDER=local

# Gemini embeddings (requires AUDREY_EMBEDDING_PROVIDER=gemini)
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# OpenAI embeddings (must set AUDREY_EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=

# LLM provider for consolidation/reflection: anthropic | openai (auto-detected)
# AUDREY_LLM_PROVIDER=anthropic
# AUDREY_LLM_MODEL=
# ANTHROPIC_API_KEY=

# Autopilot lifecycle hooks
# AUDREY_AUTOPILOT_SCOPE=agent
# AUDREY_CONTEXT_BUDGET_CHARS=4000
# AUDREY_HOOK_FAIL_CLOSED=0

# REST API server
# AUDREY_PORT=7437
# AUDREY_API_KEY=
# AUDREY_ENABLE_SHARED_SCOPE=0

# Local embedding device: gpu | cpu (default: gpu)
# AUDREY_DEVICE=gpu
