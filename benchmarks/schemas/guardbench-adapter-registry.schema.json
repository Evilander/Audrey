{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audrey-memory.org/schemas/guardbench-adapter-registry.schema.json",
  "title": "GuardBench Adapter Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "adapters"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "suite": { "const": "GuardBench adapter registry" },
    "adapters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/adapter" }
    }
  },
  "$defs": {
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "path",
        "status",
        "credentialMode",
        "requiredEnv",
        "description",
        "commands"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "path": {
          "type": "string",
          "pattern": "^benchmarks/adapters/.+\\.mjs$"
        },
        "status": {
          "enum": ["reference", "external-system", "experimental"]
        },
        "credentialMode": {
          "enum": ["none", "runtime-env"]
        },
        "requiredEnv": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          }
        },
        "description": { "type": "string", "minLength": 1 },
        "commands": {
          "type": "object",
          "additionalProperties": false,
          "required": ["moduleValidate", "selfTest", "selfTestValidate", "externalRun"],
          "properties": {
            "moduleValidate": { "type": "string", "minLength": 1 },
            "selfTest": { "type": "string", "minLength": 1 },
            "selfTestValidate": { "type": "string", "minLength": 1 },
            "externalRun": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
