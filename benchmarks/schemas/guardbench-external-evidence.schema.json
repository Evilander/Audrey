{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audrey-memory.org/schemas/guardbench-external-evidence.schema.json",
  "title": "GuardBench External Evidence Verification",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "generatedAt", "ok", "allowPending", "registry", "outRoot", "adapters", "failures"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "suite": { "const": "GuardBench external evidence verification" },
    "generatedAt": { "type": "string", "minLength": 1 },
    "ok": { "type": "boolean" },
    "allowPending": { "type": "boolean" },
    "registry": { "type": "string", "minLength": 1 },
    "outRoot": { "type": "string", "minLength": 1 },
    "adapters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/adapterEvidence" }
    },
    "failures": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "adapterEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "path",
        "credentialMode",
        "requiredEnv",
        "outDir",
        "metadataPath",
        "status",
        "evidenceKind",
        "metadataStatus",
        "dryRun",
        "missingEnv",
        "artifactValidationOk",
        "adapterConformanceOk",
        "secretLeakCount",
        "failures"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "credentialMode": { "const": "runtime-env" },
        "requiredEnv": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "outDir": { "type": "string", "minLength": 1 },
        "metadataPath": { "type": "string", "minLength": 1 },
        "status": {
          "enum": ["failed", "pending", "verified"]
        },
        "evidenceKind": {
          "enum": ["blocked", "dry-run", "live", "missing"]
        },
        "metadataStatus": {
          "anyOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "dryRun": {
          "anyOf": [
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "missingEnv": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "artifactValidationOk": {
          "anyOf": [
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "adapterConformanceOk": {
          "anyOf": [
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "secretLeakCount": {
          "type": "integer",
          "minimum": 0
        },
        "failures": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
